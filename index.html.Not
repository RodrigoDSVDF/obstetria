<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dra. Olívia Versiani | Ginecologia e Obstetrícia</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-primary: #8e735b;
            --brand-secondary: #f4efea;
            --brand-accent: #c5a88e;
            --text-dark: #2d2a26;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-dark);
            background-color: #fff;
            scroll-behavior: smooth;
        }

        .font-serif {
            font-family: 'Playfair Display', serif;
        }

        .text-brand { color: var(--brand-primary); }
        .bg-brand { background-color: var(--brand-primary); }
        .bg-brand-light { background-color: var(--brand-secondary); }

        .glass-header {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(142, 115, 91, 0.1);
        }

        /* Estilo da Logo Beija-flor Atrás do Nome */
        .header-logo-container {
            position: absolute;
            left: -25px; /* Ajuste para mobile */
            top: 50%;
            transform: translateY(-50%);
            z-index: 0;
            pointer-events: none;
            opacity: 0.7;
        }

        .header-logo-img {
            width: 75px;
            height: auto;
            display: block;
        }

        @media (min-width: 768px) {
            .header-logo-container {
                left: -35px;
            }
            .header-logo-img {
                width: 90px;
            }
        }

        .service-card {
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .service-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(142, 115, 91, 0.1);
        }

        .btn-hover-effect {
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .btn-hover-effect:after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0%;
            height: 2px;
            background-color: currentColor;
            transition: width 0.3s ease;
        }

        .btn-hover-effect:hover:after {
            width: 100%;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .reveal {
            animation: fadeIn 1s ease forwards;
        }

        /* Hero Background - Substituir pelas suas fotos se desejar */
        .bg-hero {
            background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('01.png');
            background-size: cover;
            background-position: center;
        }
    </style>
</head>
<body>

    <!-- Cabeçalho (Header) -->
    <header class="glass-header fixed w-full z-50 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 md:px-6 h-20 flex items-center justify-between">
            
            <!-- Identidade Visual -->
            <div class="flex flex-col min-w-0 relative">
                <!-- A Logo Beija-flor (Atrás do Nome) -->
                <div class="header-logo-container">
                    <!-- Certifique-se de que a imagem está na mesma pasta com o nome logo.jpg -->
                    <img src="logo.jpg" alt="Logo Dra. Olívia" class="header-logo-img" onerror="this.style.display='none'">
                </div>

                <span class="font-serif text-xl md:text-2xl font-bold tracking-tight text-brand truncate relative z-10">DRA. OLÍVIA VERSIANI</span>
                <span class="text-[9px] md:text-[10px] tracking-[0.12em] md:tracking-[0.2em] uppercase opacity-80 truncate relative z-10 font-medium">Ginecologia & Obstetrícia</span>
            </div>
            
            <!-- Menu Desktop -->
            <nav class="hidden lg:flex space-x-8 text-sm font-medium">
                <a href="#inicio" class="btn-hover-effect py-1">Início</a>
                <a href="#dra" class="btn-hover-effect py-1">A Médica</a>
                <a href="#servicos" class="btn-hover-effect py-1">Especialidades</a>
                <a href="#depoimentos" class="btn-hover-effect py-1">Depoimentos</a>
                <a href="#contato" class="btn-hover-effect py-1">Contacto</a>
            </nav>

            <!-- Botão de Acção -->
            <a href="https://wa.me/5562999999999" target="_blank" class="bg-brand text-white px-4 md:px-6 py-2 md:py-2.5 rounded-full text-xs md:text-sm font-medium hover:bg-opacity-90 transition-all shadow-md relative z-20">
                Agendar <span class="hidden sm:inline">Consulta</span>
            </a>
        </div>
    </header>

    <!-- Secção Hero -->
    <section id="inicio" class="relative bg-hero min-h-screen flex items-center overflow-hidden">
        <div class="relative max-w-7xl mx-auto px-6 w-full z-10 pt-20">
            <div class="reveal max-w-2xl">
                <span class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md border border-white/30 text-white text-[10px] md:text-xs font-semibold mb-6 shadow-sm uppercase tracking-widest">Goiânia | Órion Business</span>
                <h1 class="font-serif text-4xl md:text-7xl leading-tight mb-6 text-white drop-shadow-lg">
                    Cuidado integral à <br><span class="italic text-white/90">saúde da mulher.</span>
                </h1>
                <p class="text-base md:text-lg text-white mb-8 max-w-lg leading-relaxed font-medium drop-shadow-md">
                    Atendimento humanizado focado em ginecologia e obstetrícia de alto risco em todas as fases da vida.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="#servicos" class="bg-brand text-white px-8 py-4 rounded-full font-medium hover:shadow-xl transition-all text-sm md:text-base">
                        Ver Especialidades
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Secção de Especialidades -->
    <section id="servicos" class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="font-serif text-3xl md:text-4xl mb-4">Especialidades & Cuidados</h2>
                <div class="w-12 h-0.5 bg-brand mx-auto opacity-40"></div>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <!-- Card 1 -->
                <div class="service-card p-8 bg-brand-light rounded-3xl border border-brand/5">
                    <h3 class="font-serif text-xl mb-4 text-brand">Ginecologia</h3>
                    <p class="text-sm text-gray-600 leading-relaxed">Check-up preventivo, tratamento de endometriose e climatério com olhar atento.</p>
                </div>
                <!-- Card 2 -->
                <div class="service-card p-8 bg-white rounded-3xl border border-brand/10 shadow-sm">
                    <h3 class="font-serif text-xl mb-4 text-brand">Obstetrícia</h3>
                    <p class="text-sm text-gray-600 leading-relaxed">Pré-natal humanizado e assistência em partos com foco na segurança e bem-estar.</p>
                </div>
                <!-- Card 3 -->
                <div class="service-card p-8 bg-brand-light rounded-3xl border border-brand/5">
                    <h3 class="font-serif text-xl mb-4 text-brand">Microscopia</h3>
                    <p class="text-sm text-gray-600 leading-relaxed">Diagnóstico imediato de corrimentos recorrentes através da análise microscópica.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Rodapé -->
    <footer id="contato" class="bg-brand text-white py-16">
        <div class="max-w-7xl mx-auto px-6 text-center md:text-left">
            <div class="grid md:grid-cols-3 gap-12 mb-12">
                <div>
                    <span class="font-serif text-2xl font-bold mb-2 block">Dra. Olívia Versiani</span>
                    <p class="opacity-70 text-sm">CRM-GO 38362 | RQE 6789</p>
                </div>
                <div>
                    <h4 class="text-xs font-bold uppercase tracking-widest mb-4">Localização</h4>
                    <p class="opacity-70 text-sm">Órion Business & Health Complex<br>Setor Marista, Goiânia - GO</p>
                </div>
                <div>
                    <h4 class="text-xs font-bold uppercase tracking-widest mb-4">Redes Sociais</h4>
                    <a href="#" class="text-sm opacity-70 hover:opacity-100 transition-opacity">Instagram @draoliviaversiani</a>
                </div>
            </div>
            <div class="border-t border-white/10 pt-8 text-center text-[9px] uppercase tracking-widest opacity-40">
                © 2026 Dra. Olívia Versiani. Todos os direitos reservados.
            </div>
        </div>
    </footer>

    <!-- Botão Flutuante WhatsApp -->
    <a href="https://wa.me/5562999999999" target="_blank" class="fixed bottom-6 right-6 bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-transform z-50">
        <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 21.082h-.006a9.923 9.923 0 0 1-5.05-1.378l-.36-.214-3.748.98 1.002-3.652-.235-.374a9.954 9.954 0 0 1-1.52-5.328C2.115 5.568 7.747.012 14.542.012c3.344 0 6.486 1.303 8.847 3.667a12.518 12.518 0 0 1 3.611 8.842c0 6.877-5.632 12.433-12.427 12.433zm-4.995-3.328c1.551.921 3.332 1.408 5.161 1.408 5.753 0 10.435-4.68 10.435-10.434 0-2.791-1.087-5.414-3.059-7.387A10.536 10.536 0 0 0 14.542 2.01c-5.752 0-10.434 4.68-10.434 10.434 0 1.936.543 3.823 1.572 5.438l-1.636 5.96 6.136-1.605c-.05-.084-.09-.17-.134-.255zm8.125-6.31c-.426-.214-2.52-1.246-2.914-1.388-.393-.142-.681-.214-.969.213-.288.428-1.1 1.388-1.348 1.673-.248.285-.497.321-.923.107-1.924-.963-3.385-2.073-4.48-3.79-.214-.334.214-.316.635-.916.143-.214.288-.428.432-.642.144-.214.072-.428-.035-.642-.108-.214-.969-2.338-1.328-3.2-.35-.845-.705-.731-.968-.745-.25-.013-.538-.013-.826-.013-.288 0-.756.107-1.15.535-.394.428-1.503 1.47-1.503 3.585 0 2.115 1.54 4.158 1.754 4.444.214.285 3.033 4.63 7.345 6.49 1.026.442 1.826.706 2.451.904 1.031.328 1.968.281 2.708.17 1.401-.21 3.535-1.444 4.032-2.84.497-1.396.497-2.593.348-2.842-.148-.25-.538-.392-.964-.606z"/></svg>
    </a>

    <script>
        // Função simples para animação ao rolar (scroll)
        window.addEventListener('scroll', () => {
            const reveals = document.querySelectorAll('.reveal');
            reveals.forEach(el => {
                const elementTop = el.getBoundingClientRect().top;
                if (elementTop < window.innerHeight - 100) {
                    el.style.opacity = '1';
                    el.style.transform = 'translateY(0)';
                }
            });
        });
    </script>
</body>
</html>
